/// Optional ignored fallback for local release scripts.
///
/// The Flutter app itself reads SUPABASE_URL and SUPABASE_PUBLISHABLE_KEY from
/// --dart-define through SupabaseRuntimeConfig. Copy this file to
/// lib/secrets.dart only when you want scripts such as store_release_build.ps1
/// or release_readiness_audit.ps1 to read a local fallback instead of process
/// environment values.
///
/// Do not commit lib/secrets.dart. It is intentionally gitignored.
class SupabaseConfig {
  static const String url = 'https://YOUR_PROJECT_REF.supabase.co';
  static const String publishableKey = 'sb_publishable_YOUR_KEY';

  @Deprecated('Use publishableKey instead.')
  static const String anonKey = publishableKey;
}
