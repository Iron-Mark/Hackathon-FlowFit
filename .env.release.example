# Copy to .env.release and fill values on the release machine.
# Do not commit .env.release.

FLOWFIT_SUPPORT_EMAIL=support@flowfit.com
FLOWFIT_SUPPORT_EMAIL_VERIFIED=false
FLOWFIT_PUBLIC_WEB_BASE_URL=https://flowfit.your-owned-domain.com
# Optional for static hosts served from a subpath, for example GitHub Pages.
# If omitted, scripts/store_release_build.ps1 derives it from FLOWFIT_PUBLIC_WEB_BASE_URL.
# FLOWFIT_WEB_BASE_HREF=/Hackathon-FlowFit/

SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=REPLACE_WITH_SUPABASE_PUBLISHABLE_KEY

ORG_GRADLE_PROJECT_FLOWFIT_ANDROID_APPLICATION_ID=com.oldstlabs.flowfit
ORG_GRADLE_PROJECT_FLOWFIT_AUTH_SCHEME=com.oldstlabs.flowfit

# Optional on macOS when Xcode signing requires an explicit export profile.
# FLOWFIT_IOS_EXPORT_OPTIONS_PLIST=/Users/you/export_options.plist
