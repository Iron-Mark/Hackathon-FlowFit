# Copy to .env.release and fill values on the release machine.
# Do not commit .env.release.

FLOWFIT_SUPPORT_EMAIL=REPLACE_WITH_FLOWFIT_SUPPORT_EMAIL
FLOWFIT_SUPPORT_EMAIL_VERIFIED=false
FLOWFIT_PUBLIC_WEB_BASE_URL=https://iron-mark.github.io/Hackathon-FlowFit
# Optional for static hosts served from a subpath, for example GitHub Pages.
# If omitted, scripts/store_release_build.ps1 derives it from FLOWFIT_PUBLIC_WEB_BASE_URL.
# FLOWFIT_WEB_BASE_HREF=/Hackathon-FlowFit/
# Optional custom map tile provider. Defaults to CARTO Voyager when omitted.
# Do not use public tile.openstreetmap.org for production traffic.
# FLOWFIT_MAP_TILE_URL_TEMPLATE=https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}.png
# FLOWFIT_MAP_TILE_SUBDOMAINS=a,b,c

SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=REPLACE_WITH_SUPABASE_PUBLISHABLE_KEY

# Optional live Supabase app smoke test credentials.
# Use a dedicated confirmed test user only, for example
# maintainer+flowfit-smoke@example.com. The smoke script refuses non-smoke
# emails unless explicitly overridden and cleans up app rows by default.
# FLOWFIT_SMOKE_EMAIL=maintainer+flowfit-smoke@example.com
# FLOWFIT_SMOKE_PASSWORD=REPLACE_WITH_CONFIRMED_TEST_USER_PASSWORD

ORG_GRADLE_PROJECT_FLOWFIT_ANDROID_APPLICATION_ID=com.msiazondev.flowfit
ORG_GRADLE_PROJECT_FLOWFIT_AUTH_SCHEME=com.msiazondev.flowfit

# Optional CI/local signing alternative to android/key.properties.
# Keep these only in ignored .env.release or GitHub repository secrets.
# FLOWFIT_ANDROID_KEYSTORE_BASE64=REPLACE_WITH_BASE64_ENCODED_UPLOAD_KEYSTORE
# FLOWFIT_ANDROID_KEYSTORE_PASSWORD=REPLACE_WITH_UPLOAD_KEYSTORE_PASSWORD
# FLOWFIT_ANDROID_KEY_ALIAS=upload
# FLOWFIT_ANDROID_KEY_PASSWORD=REPLACE_WITH_UPLOAD_KEY_PASSWORD
# FLOWFIT_ANDROID_KEYSTORE_FILE_NAME=upload-keystore.jks

# Optional on macOS when Xcode signing requires an explicit export profile.
# Create an ignored repo-local plist with scripts/create_ios_export_options.ps1.
# FLOWFIT_IOS_EXPORT_OPTIONS_PLIST=/Users/you/export_options.plist
